# ============================================================================
# 🤖 OPENAI CONFIGURATION - Optional (Chatbot has fallback without it)
# ============================================================================
# Leave empty to use fallback response generator (works without API key)
# Add your key if you want premium AI responses
OPENAI_API_KEY=

# ============================================================================
# 💾 DATABASE CONFIGURATION
# ============================================================================
DATABASE_URL=sqlite:///./agripredict.db
DATABASE_USER=
DATABASE_PASSWORD=

# ============================================================================
# 🖥️ APP CONFIGURATION
# ============================================================================
APP_ENV=development
APP_PORT=8000
APP_DEBUG=True
DEBUG=False
HOST=0.0.0.0
PORT=8000

# ============================================================================
# 🔐 SECURITY SETTINGS
# ============================================================================
SECRET_KEY=your-super-secret-key-change-in-production-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# 🌐 CORS SETTINGS
# ============================================================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://127.0.0.1:3000","http://127.0.0.1:8000","*"]

# ============================================================================
# 🌦️ EXTERNAL SERVICES - Optional (Leave empty if not using)
# ============================================================================
WEATHER_API_KEY=
MARKET_DATA_API_KEY=
SERVICE_URL=
SERVICE_API_KEY=

# ============================================================================
# 📧 EMAIL CONFIGURATION (Gmail SMTP) - Optional
# ============================================================================
GMAIL_EMAIL=
GMAIL_APP_PASSWORD=

# ============================================================================
# 📱 SMS CONFIGURATION - TWILIO - Optional
# ============================================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ============================================================================
# 📱 SMS CONFIGURATION - FAST2SMS (India) - Optional
# ============================================================================
FAST2SMS_API_KEY=
FAST2SMS_ROUTE=q

# SMS Provider: "twilio" or "fast2sms"
SMS_PROVIDER=twilio

# ============================================================================
# 🤖 CHATBOT & AI SETTINGS
# ============================================================================
# OpenAI key (optional - chatbot has fallback)
OPENAI_API_KEY=

# Enable fallback responses when OpenAI not available
ENABLE_OPENAI_FALLBACK=True

# Translation (optional)
GOOGLE_TRANSLATE_API_KEY=

# Voice & Multilingual Features
ENABLE_VOICE=True
ENABLE_MULTILINGUAL=True
CONVERSATION_MEMORY_SIZE=5
DEFAULT_LANGUAGE=en

# ============================================================================
# 📊 LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=INFO

# ============================================================================
# 🌾 AGRIPREDICT-SPECIFIC SETTINGS
# ============================================================================
PROJECT_NAME=AgriPredictAI
API_VERSION=1.0.0
